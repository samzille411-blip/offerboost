# 复制为 .env.local（勿提交 Git）

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
# 免费分析：便宜模型 Flash（约 Pro 的 1/3 价，见 api-docs.deepseek.com）
LLM_MODEL_ANALYZE=deepseek-v4-flash
# 卡密解锁报告：高质量模型 Pro
LLM_MODEL_PREMIUM=deepseek-v4-pro
# 兜底（可不填，上面两个优先）
LLM_MODEL=deepseek-v4-flash
LLM_ANALYZE_MAX_TOKENS=300

NEXT_PUBLIC_SHOP_URL_EXP=
NEXT_PUBLIC_SHOP_URL_STD=
NEXT_PUBLIC_SHOP_URL_VIP=

NEXT_PUBLIC_SITE_NAME=OfferBoost
NEXT_PUBLIC_LEGACY_SITE_URL=http://120.27.247.36/
NEXT_PUBLIC_COMPLIANCE_NOTICE=本站为 AI 简历优化工具展示平台，不涉及在线交易；卡密请通过合作平台获取。
NEXT_PUBLIC_ICP=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_ANALYZE=10
RATE_LIMIT_MAX_USE_CARD=5
RATE_LIMIT_MAX_PROBE=10

# 探活：首次分析前极轻量调用（约 5 token），同会话 1h 内不重复探活
LLM_PROBE_MAX_TOKENS=5
LLM_PROBE_CACHE_MS=3600000
